---
// SEÇÃO 6 — FRASE DE IMPACTO
// FOTO (fundo): jady-fosforo-close.jpg
// Close extremo com fósforo aceso, lábios vermelhos, metade do rosto iluminada
---

<section class="frase-impacto noise" aria-label="Frase de impacto">
  <!-- Foto de fundo -->
  <div class="frase-impacto__bg">
    <img
      src="/images/jady-fosforo-close.jpg"
      alt="Close de Jady Mota com fósforo aceso em frente ao rosto, metade iluminada"
      class="frase-impacto__img"
      loading="lazy"
    />
    <div class="frase-impacto__overlay"></div>
  </div>

  <div class="container frase-impacto__content">
    <div class="frase-impacto__inner fade-in">
      <span class="frase-impacto__ornament" aria-hidden="true">◆</span>

      <blockquote class="frase-impacto__quote">
        "O espaço interno torna-se um terreno fértil
        onde qualquer coisa pode florescer."
      </blockquote>

      <cite class="frase-impacto__cite">7 de Ouros</cite>
    </div>
  </div>
</section>

<style>
  .frase-impacto {
    position: relative;
    padding-block: clamp(100px, 14vw, 180px);
    overflow: hidden;
    text-align: center;
  }

  /* Foto de fundo */
  .frase-impacto__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .frase-impacto__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    filter: grayscale(20%);
  }

  .frase-impacto__overlay {
    position: absolute;
    inset: 0;
    background: rgba(43, 10, 10, 0.82);
  }

  /* Conteúdo */
  .frase-impacto__content {
    position: relative;
    z-index: 2;
  }

  .frase-impacto__inner {
    max-width: 720px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .frase-impacto__ornament {
    font-size: 10px;
    color: rgba(201, 168, 76, 0.5);
    letter-spacing: 0.3em;
    display: block;
    margin-bottom: 8px;
  }

  .frase-impacto__quote {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(22px, 3.5vw, 38px);
    font-weight: 300;
    font-style: italic;
    line-height: 1.5;
    color: var(--cream);
    letter-spacing: 0.01em;
    quotes: none;
  }

  .frase-impacto__cite {
    font-family: 'Jost', sans-serif;
    font-size: 12px;
    font-weight: 300;
    font-style: normal;
    letter-spacing: 0.15em;
    color: var(--gold);
    text-transform: uppercase;
  }
</style>
